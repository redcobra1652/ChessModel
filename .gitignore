# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl
*.spec

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Stockfish binary ───────────────────────────────────────────────────────────
# The entire stockfish/ directory (pre-built binaries, source tree, large assets)
stockfish/

# ── Files over 50 MB (common large artefacts) ─────────────────────────────────
# replay buffer
replay_buffer.pkl
# warm-train PGN datasets
warm_train/*.pgn
# all PGN files anywhere in the repo
*.pgn

# ── PyTorch model checkpoints ──────────────────────────────────────────────────
# Ignore all .pt / .pth / .ckpt checkpoint files by default …
*.pt
*.pth
*.ckpt
# … EXCEPT the two canonical best-model files that are worth tracking.
!best_model.pt
!best_model_6x64_1920.pt

# ── Compiled C++ engine binary ─────────────────────────────────────────────────
mcts_engine

# ── Training logs ─────────────────────────────────────────────────────────────
stockfish_curriculum_log.jsonl

# ── macOS system files ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── IDE / editor ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs & temporary files ────────────────────────────────────────────────────
*.log
*.tmp
*.bak

# ── Jupyter Notebooks (if used) ───────────────────────────────────────────────
.ipynb_checkpoints/
